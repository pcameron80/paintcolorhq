# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# debug artifacts kept locally only
.playwright-mcp/
*.bak
/stitch_palette_visualizer/

# loose screenshots / scratch in repo root
/*.png
/*.jpg
/*.jpeg

# typescript
*.tsbuildinfo
next-env.d.ts

# data
/data/

# secrets
client_secret_*.json

# routine artifacts (local-only — not source)
/drafts/
/reports/
/docs/blog-calendar.md
