# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# debug artifacts kept locally only
.playwright-mcp/
*.bak
/stitch_palette_visualizer/

# loose screenshots / scratch in repo root
/*.png
/*.jpg
/*.jpeg

# typescript
*.tsbuildinfo
next-env.d.ts

# data
/data/

# secrets
client_secret_*.json

# routine artifacts (local-only — not source)
/drafts/
/reports/
/docs/blog-calendar.md

# scrape caches (local-only — re-fetchable from manufacturer sites)
/scripts/data/

# pre-computed match data (regenerated at build time by scripts/build-match-data.ts)
/public/match-data/

# Drift detection runtime data (SQLite)
scripts/drift/*.db
scripts/drift/*.db-shm
scripts/drift/*.db-wal

# Pinterest runtime state (pin IDs + drip log; not secrets, but runtime-only)
scripts/pinterest/published*.json
scripts/pinterest/drip.log
scripts/pinterest/analytics.log
scripts/pinterest/reports/
scripts/pinterest/preview.html

# Social drip run logs (runtime-only; the published.json ledgers ARE tracked)
scripts/facebook/drip.log
scripts/instagram/drip.log

# Python bytecode (e.g. the drift compare tooling)
__pycache__/
*.pyc

# SEO audit derived/binary artifacts — keep the markdown reports tracked,
# not the heavy PDF/HTML/screenshot/script outputs (4MB+ per full audit).
seo-audits/**/screenshots/
seo-audits/**/*.pdf
seo-audits/**/*.html
seo-audits/**/*.py
