{
  "crons": [
    {
      "path": "/api/cron/indexnow",
      "schedule": "23 8 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "paintcolorhq.com"
        }
      ],
      "destination": "https://www.paintcolorhq.com/:path",
      "permanent": true
    }
  ]
}
